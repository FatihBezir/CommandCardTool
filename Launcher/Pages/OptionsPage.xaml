<Page
    x:Class="LauncherWinUI.Pages.OptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#01031A">

    <Page.Resources>
        <!-- Nav tab RadioButton style -->
        <Style x:Key="NavTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="RootBorder"
                            Background="#01031A"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#040C52"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#2980FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#020830"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Back button style -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01031A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,8,4,4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2980FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextBlock.Foreground="{TemplateBinding Foreground}"
                                TextBlock.FontSize="{TemplateBinding FontSize}"
                                TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numeric TextBox style -->
        <Style x:Key="NumericBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2980FF"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Field label style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="220"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Grid Grid.Column="0" Background="#00020F">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,0">
                <RadioButton x:Name="rbCamera" Content="CAMERA" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" IsChecked="True"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="rbChat" Content="CHAT" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbInput" Content="INPUT" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbGraphics" Content="GRAPHICS" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbSocial" Content="SOCIAL" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbNetwork" Content="NETWORK" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
            </StackPanel>

            <Button Grid.Row="1" x:Name="btnBack"
                    Content="SAVE &amp; GO BACK"
                    Style="{StaticResource BackButtonStyle}"
                    Click="BtnBack_Click"/>
        </Grid>

        <!-- Content area -->
        <ScrollViewer Grid.Column="1" Padding="24,20,24,20" VerticalScrollBarVisibility="Auto"
                      Background="#01031A">

            <!-- All panels overlap in the same cell — only one visible at a time -->
            <Grid>
                <!-- CAMERA -->
                <StackPanel x:Name="PanelCamera" Visibility="Visible">
                    <TextBlock Text="CAMERA" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Maximum Camera Height *"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtMaxCameraHeight"
                                 Style="{StaticResource NumericBoxStyle}" Text="310"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="* Only applies when you are the lobby host"
                                   Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum Camera Height"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtMinCameraHeight"
                                 Style="{StaticResource NumericBoxStyle}" Text="210"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Camera Movement Speed (%)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtCameraMovementSpeed"
                                 Style="{StaticResource NumericBoxStyle}" Text="100"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                    </Grid>
                </StackPanel>

                <!-- CHAT -->
                <StackPanel x:Name="PanelChat" Visibility="Collapsed">
                    <TextBlock Text="CHAT" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Fade Out Duration (Seconds)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtChatDuration"
                                 Style="{StaticResource NumericBoxStyle}" Text="30"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                    </StackPanel>
                </StackPanel>

                <!-- INPUT -->
                <StackPanel x:Name="PanelInput" Visibility="Collapsed">
                    <TextBlock Text="INPUT" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="chkCursorLockWindowed"
                                  Content="Cursor Lock (Windowed)"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkCursorLockFullscreen"
                                  Content="Cursor Lock (Fullscreen)"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="chkEdgeScrollingWindowed"
                                  Content="Edge Scrolling (Windowed)"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkEdgeScrollingFullscreen"
                                  Content="Edge Scrolling (Fullscreen)"/>
                    </Grid>
                </StackPanel>

                <!-- GRAPHICS -->
                <StackPanel x:Name="PanelGraphics" Visibility="Collapsed" Margin="0,0,0,0">
                    <TextBlock Text="GRAPHICS" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox x:Name="chkLimitFramerate" Content="Limit Framerate"
                                  Checked="ChkLimitFramerate_Changed"
                                  Unchecked="ChkLimitFramerate_Changed"
                                  VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBox x:Name="txtFPSLimit"
                                 Style="{StaticResource NumericBoxStyle}" Text="60"
                                 IsEnabled="False"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                        <TextBlock Text="FPS" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="chkStatsOverlay" Content="Show Statistics Overlay"/>
                    <CheckBox x:Name="chkWindowed" Content="Windowed" Margin="0,8,0,4"
                              Checked="ChkWindowed_Changed"
                              Unchecked="ChkWindowed_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Windowed Resolution" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cmbWindowedResolution" Width="160" IsEnabled="False"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060"/>
                    </StackPanel>
                </StackPanel>

                <!-- SOCIAL -->
                <StackPanel x:Name="PanelSocial" Visibility="Collapsed">
                    <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="In-Game"
                                   Foreground="#888888" FontSize="11" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="In Menus"
                                   Foreground="#888888" FontSize="11" Margin="0,0,0,6"/>

                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="chkFriendOnlineInGame"
                                  Content="Friend Comes Online (In-Game)"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkFriendOnlineInMenus"
                                  Content="Friend Comes Online (In Menus)"/>
                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="chkFriendOfflineInGame"
                                  Content="Friend Goes Offline (In-Game)"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkFriendOfflineInMenus"
                                  Content="Friend Goes Offline (In Menus)"/>
                        <CheckBox Grid.Row="3" Grid.Column="0" x:Name="chkFriendRequestInGame"
                                  Content="Incoming Friend Request (In-Game)"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="chkFriendRequestInMenus"
                                  Content="Incoming Friend Request (In Menus)"/>
                        <CheckBox Grid.Row="4" Grid.Column="0" x:Name="chkFriendAcceptedInGame"
                                  Content="Outgoing Request Accepted (In-Game)"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="chkFriendAcceptedInMenus"
                                  Content="Outgoing Request Accepted (In Menus)"/>
                    </Grid>
                </StackPanel>

                <!-- NETWORK -->
                <StackPanel x:Name="PanelNetwork" Visibility="Collapsed">
                    <TextBlock Text="NETWORK" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock
                        Text="⚠ These are advanced options that you should not change unless you know what you are doing."
                        Foreground="#FF6060" FontWeight="Bold" FontSize="12"
                        TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="HTTP Version" Style="{StaticResource FieldLabelStyle}" MinWidth="100"/>
                        <ComboBox x:Name="cmbHTTPVersion" Width="200" SelectedIndex="0"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060">
                            <ComboBoxItem Content="Automatic"/>
                            <ComboBoxItem Content="1.0"/>
                            <ComboBoxItem Content="1.1"/>
                            <ComboBoxItem Content="2.0"/>
                            <ComboBoxItem Content="3.0"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="chkAlternativeEndpoint" Content="Use Alternative Endpoints"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
