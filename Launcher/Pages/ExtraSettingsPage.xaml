<Page
    x:Class="LauncherWinUI.Pages.ExtraSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#01031A">

    <Page.Resources>

        <!-- Back button style -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01031A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,8,4,4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2980FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextBlock.Foreground="{TemplateBinding Foreground}"
                                TextBlock.FontSize="{TemplateBinding FontSize}"
                                TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DiagButton (save / fix button) style -->
        <Style x:Key="DiagButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01031A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2980FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="#404060"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left sidebar ─────────────────────────────────────────── -->
        <Grid Grid.Column="0" Background="#00020F">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,0">
                <Border BorderBrush="#2980FF" BorderThickness="3,0,0,0"
                        Background="#040C52" Padding="13,12">
                    <TextBlock Text="EXTRA AYARLAR"
                               Foreground="White" FontWeight="Bold" FontSize="12"
                               FontFamily="Segoe UI" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <Button Grid.Row="1" x:Name="btnBack"
                    Content="← GERİ"
                    Style="{StaticResource BackButtonStyle}"
                    Click="BtnBack_Click"/>
        </Grid>

        <!-- ── Content area ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Column="1" Padding="24,20,24,20"
                      VerticalScrollBarVisibility="Auto"
                      Background="#01031A">
            <StackPanel>

                <TextBlock Text="EXTRA AYARLAR" Style="{StaticResource SectionHeaderStyle}"/>

                <!-- ── Boştaki İşçi Seçme Tuşu ───────────────────────── -->
                <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                        Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Boştaki İşçi Seçme Tuşu" FontSize="13" FontWeight="Bold"
                                   Foreground="#C8D6E5" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Tuş" Foreground="#8888AA" FontSize="11"
                                       MinWidth="70" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbIdleWorkerKey" Width="140"
                                      Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                      FontSize="12"/>
                            <TextBlock Text="Modifier" Foreground="#8888AA" FontSize="11"
                                       MinWidth="60" Margin="14,0,0,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbIdleWorkerMod" Width="140"
                                      Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                      FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Kısayol:" Foreground="#404070" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock x:Name="lblIdleWorkerShortcut" Text="—"
                                       Foreground="#00d4ff" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnSaveIdleWorker" Content="💾  BIG'e Uygula"
                                    Style="{StaticResource DiagButtonStyle}"
                                    IsEnabled="False" Click="BtnSaveIdleWorker_Click"/>
                            <TextBlock x:Name="lblIdleWorkerPath" Text="" Foreground="#404070" FontSize="10"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock x:Name="lblIdleWorkerStatus" Text="" FontSize="11"
                                   Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ── Beacon (İşaretçi) Tuşu ────────────────────────── -->
                <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                        Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Beacon (İşaretçi) Tuşu" FontSize="13" FontWeight="Bold"
                                   Foreground="#C8D6E5" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Tuş" Foreground="#8888AA" FontSize="11"
                                       MinWidth="70" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbBeaconKey" Width="140"
                                      Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                      FontSize="12"/>
                            <TextBlock Text="Modifier" Foreground="#8888AA" FontSize="11"
                                       MinWidth="60" Margin="14,0,0,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbBeaconMod" Width="140"
                                      Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                      FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Kısayol:" Foreground="#404070" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock x:Name="lblBeaconShortcut" Text="—"
                                       Foreground="#00d4ff" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnSaveBeacon" Content="💾  BIG'e Uygula"
                                    Style="{StaticResource DiagButtonStyle}"
                                    IsEnabled="False" Click="BtnSaveBeacon_Click"/>
                            <TextBlock x:Name="lblBeaconPath" Text="(BIG'de bulunamadı)"
                                       Foreground="#404070" FontSize="10"
                                       Margin="12,0,0,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock x:Name="lblBeaconStatus" Text="" FontSize="11"
                                   Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- ── Nuke General — Battlemaster Resim Düzeltmesi ──── -->
                <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                        Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Nuke General — Battlemaster Resim Düzeltmesi"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#C8D6E5" Margin="0,0,0,6"/>
                        <TextBlock FontSize="11" Foreground="#8888AA" Margin="0,0,0,10"
                                   TextWrapping="Wrap"
                                   Text="CommandButton.ini içindeki SNBattlemaster → SNNukeBtleMstr_L olarak değiştirir (Nuke General War Factory ikon düzeltmesi)."/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnNukeBattlemasterFix" Content="🔧  Düzelt"
                                    Style="{StaticResource DiagButtonStyle}"
                                    Click="BtnNukeBattlemasterFix_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="lblNukeBattlemasterStatus" Text="" FontSize="11"
                                   Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
