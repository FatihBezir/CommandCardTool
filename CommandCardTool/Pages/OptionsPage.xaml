<Page
    x:Class="LauncherWinUI.Pages.OptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#01031A">

    <Page.Resources>
        <!-- Nav tab RadioButton style -->
        <Style x:Key="NavTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="RootBorder"
                            Background="#01031A"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#040C52"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#2980FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#020830"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Back button style -->
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01031A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="4,8,4,4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2980FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextBlock.Foreground="{TemplateBinding Foreground}"
                                TextBlock.FontSize="{TemplateBinding FontSize}"
                                TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numeric TextBox style -->
        <Style x:Key="NumericBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#2980FF"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Field label style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="220"/>
        </Style>
        <!-- Diagnostics button style -->
        <Style x:Key="DiagButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01031A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#2980FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="BorderBrush" Value="#404060"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Grid Grid.Column="0" Background="#00020F">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,0">
                <RadioButton x:Name="rbCamera" Content="CAMERA" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" IsChecked="True"
                             Checked="Tab_Checked"/>
                <RadioButton x:Name="rbChat" Content="CHAT" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbInput" Content="INPUT" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbGraphics" Content="GRAPHICS" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbSocial" Content="SOCIAL" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbNetwork" Content="NETWORK" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbPlugins" Content="PLUGINS" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbCommandCard" Content="COMMAND CARD" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
                <RadioButton x:Name="rbExtraSettings" Content="EXTRA SETTINGS" GroupName="OptionsTabs"
                             Style="{StaticResource NavTabStyle}" Checked="Tab_Checked"/>
            </StackPanel>

            <Button Grid.Row="1" x:Name="btnBack"
                    Content="SAVE &amp; GO BACK"
                    Style="{StaticResource BackButtonStyle}"
                    Click="BtnBack_Click"/>
        </Grid>

        <!-- Content area -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Column="1" Padding="24,20,24,20" VerticalScrollBarVisibility="Auto"
                      Background="#01031A">

            <!-- All panels overlap in the same cell — only one visible at a time -->
            <Grid>
                <!-- CAMERA -->
                <StackPanel x:Name="PanelCamera" Visibility="Visible">
                    <TextBlock Text="CAMERA" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Maximum Camera Height *"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtMaxCameraHeight"
                                 Style="{StaticResource NumericBoxStyle}" Text="310"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="* Only applies when you are the lobby host"
                                   Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Minimum Camera Height"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtMinCameraHeight"
                                 Style="{StaticResource NumericBoxStyle}" Text="210"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Camera Movement Speed (%)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtCameraMovementSpeed"
                                 Style="{StaticResource NumericBoxStyle}" Text="100"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                    </Grid>
                </StackPanel>

                <!-- CHAT -->
                <StackPanel x:Name="PanelChat" Visibility="Collapsed">
                    <TextBlock Text="CHAT" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Fade Out Duration (Seconds)"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="txtChatDuration"
                                 Style="{StaticResource NumericBoxStyle}" Text="30"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                    </StackPanel>
                </StackPanel>

                <!-- INPUT -->
                <StackPanel x:Name="PanelInput" Visibility="Collapsed">
                    <TextBlock Text="INPUT" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="chkCursorLockWindowed"
                                  Content="Cursor Lock (Windowed)"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkCursorLockFullscreen"
                                  Content="Cursor Lock (Fullscreen)"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="chkEdgeScrollingWindowed"
                                  Content="Edge Scrolling (Windowed)"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkEdgeScrollingFullscreen"
                                  Content="Edge Scrolling (Fullscreen)"/>
                    </Grid>
                </StackPanel>

                <!-- GRAPHICS -->
                <StackPanel x:Name="PanelGraphics" Visibility="Collapsed" Margin="0,0,0,0">
                    <TextBlock Text="GRAPHICS" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox x:Name="chkLimitFramerate" Content="Limit Framerate"
                                  Checked="ChkLimitFramerate_Changed"
                                  Unchecked="ChkLimitFramerate_Changed"
                                  VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBox x:Name="txtFPSLimit"
                                 Style="{StaticResource NumericBoxStyle}" Text="60"
                                 IsEnabled="False"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"/>
                        <TextBlock Text="FPS" Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="chkStatsOverlay" Content="Show Statistics Overlay"/>
                    <CheckBox x:Name="chkWindowed" Content="Windowed" Margin="0,8,0,4"
                              Checked="ChkWindowed_Changed"
                              Unchecked="ChkWindowed_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Windowed Resolution" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cmbWindowedResolution" Width="160" IsEnabled="False"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060"/>
                    </StackPanel>
                </StackPanel>

                <!-- SOCIAL -->
                <StackPanel x:Name="PanelSocial" Visibility="Collapsed">
                    <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeaderStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="In-Game"
                                   Foreground="#888888" FontSize="11" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="In Menus"
                                   Foreground="#888888" FontSize="11" Margin="0,0,0,6"/>

                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="chkFriendOnlineInGame"
                                  Content="Friend Comes Online (In-Game)"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="chkFriendOnlineInMenus"
                                  Content="Friend Comes Online (In Menus)"/>
                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="chkFriendOfflineInGame"
                                  Content="Friend Goes Offline (In-Game)"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkFriendOfflineInMenus"
                                  Content="Friend Goes Offline (In Menus)"/>
                        <CheckBox Grid.Row="3" Grid.Column="0" x:Name="chkFriendRequestInGame"
                                  Content="Incoming Friend Request (In-Game)"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="chkFriendRequestInMenus"
                                  Content="Incoming Friend Request (In Menus)"/>
                        <CheckBox Grid.Row="4" Grid.Column="0" x:Name="chkFriendAcceptedInGame"
                                  Content="Outgoing Request Accepted (In-Game)"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="chkFriendAcceptedInMenus"
                                  Content="Outgoing Request Accepted (In Menus)"/>
                    </Grid>
                </StackPanel>

                <!-- NETWORK -->
                <StackPanel x:Name="PanelNetwork" Visibility="Collapsed">
                    <TextBlock Text="NETWORK" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock
                        Text="⚠ These are advanced options that you should not change unless you know what you are doing."
                        Foreground="#FF6060" FontWeight="Bold" FontSize="12"
                        TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="HTTP Version" Style="{StaticResource FieldLabelStyle}" MinWidth="100"/>
                        <ComboBox x:Name="cmbHTTPVersion" Width="200" SelectedIndex="0"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060">
                            <ComboBoxItem Content="Automatic"/>
                            <ComboBoxItem Content="1.0"/>
                            <ComboBoxItem Content="1.1"/>
                            <ComboBoxItem Content="2.0"/>
                            <ComboBoxItem Content="3.0"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="chkAlternativeEndpoint" Content="Use Alternative Endpoints"/>

                    <!-- ── DIAGNOSTICS ──────────────────────────────────────── -->
                    <Rectangle Height="1" Fill="#252550" Margin="0,16,0,16"/>
                    <TextBlock Text="DIAGNOSTICS" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="btnRunDiagnostics"
                                Content="▶  RUN DIAGNOSTICS"
                                Style="{StaticResource DiagButtonStyle}"
                                Margin="0,0,10,0"
                                Click="BtnRunDiagnostics_Click"/>
                        <Button x:Name="btnCopyDiag"
                                Content="⎘  COPY"
                                Style="{StaticResource DiagButtonStyle}"
                                IsEnabled="False"
                                Click="BtnCopyDiag_Click"/>
                    </StackPanel>

                    <!-- Results panel — hidden until first run -->
                    <Border x:Name="panelDiagResults" Visibility="Collapsed"
                            Background="#07091C" BorderBrush="#2A2A55" BorderThickness="1"
                            Padding="14,12,14,14" Margin="0,0,0,10">
                        <StackPanel>

                            <!-- Internet baseline -->
                            <TextBlock Text="INTERNET" Foreground="#404070" FontSize="10"
                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotGeo" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Your Location" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valGeo" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotCF" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Cloudflare" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valCF" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotDl" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Download Speed" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valDl" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Ellipse x:Name="dotUl" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Upload Speed" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valUl" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Game server -->
                            <TextBlock Text="GAME SERVER" Foreground="#404070" FontSize="10"
                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,10,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotDns" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="DNS Resolution" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valDns" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotPing" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Server Ping  (ICMP)" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valPing" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotProto" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Protocol" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valProto" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotHttp" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="HTTP Latency" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valHttp" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Ellipse x:Name="dotServer" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="Server Status" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valServer" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Connectivity -->
                            <TextBlock Text="CONNECTIVITY" Foreground="#404070" FontSize="10"
                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,10,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotCdn" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="CDN  cdn.playgenerals.online" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valCdn" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotStun" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="STUN  stun.playgenerals.online" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valStun" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Ellipse x:Name="dotTurn" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="TURN  turn.playgenerals.online" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valTurn" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Ellipse x:Name="dotNat" Width="8" Height="8" Fill="#404070"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="NAT Type" Foreground="#8888AA"
                                           FontSize="12" VerticalAlignment="Center" MinWidth="210"/>
                                <TextBlock x:Name="valNat" Text="—" Foreground="#606080"
                                           FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Run log — last 10 results -->
                    <TextBlock Text="LOG" Foreground="#404070" FontSize="10"
                               FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <Border Background="#07091C" BorderBrush="#2A2A55" BorderThickness="1"
                            Padding="10,8" MaxHeight="130">
                        <ScrollViewer x:Name="diagLogScroller" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="diagLog"/>
                        </ScrollViewer>
                    </Border>

                </StackPanel>

                <!-- PLUGINS -->
                <StackPanel x:Name="PanelPlugins" Visibility="Collapsed">
                    <TextBlock Text="PLUGINS" Style="{StaticResource SectionHeaderStyle}"/>
                    
                    <!-- ANTICHEAT -->
                    <TextBlock Text="ANTICHEAT" Foreground="#8888AA" FontSize="12" FontWeight="Bold" 
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Plugin" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="cmbAnticheatPlugin" Width="250"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                  SelectionChanged="CmbAnticheatPlugin_SelectionChanged"/>
                    </StackPanel>
                    
                    <!-- Configuration Details -->
                    <TextBlock Text="CONFIGURATION" Foreground="#8888AA" FontSize="12" FontWeight="Bold" 
                               Margin="0,0,0,8"/>
                    <Border Background="#07091C" BorderBrush="#2A2A55" BorderThickness="1"
                            Padding="14,12" MaxHeight="400" Margin="0,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="configDetailsPanel">
                                <TextBlock Text="(No plugin selected)" Foreground="#A0A0C0" FontSize="11"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- EXTRA SETTINGS -->
                <StackPanel x:Name="PanelExtraSettings" Visibility="Collapsed">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"
                                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#040C52"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#020630"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#5F6C86"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter TargetName="border" Property="Background" Value="#070D22"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#1E2A44"/>
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="EXTRA SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Idle Worker Key -->
                    <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Select Idle Worker Key" FontSize="13" FontWeight="Bold"
                                       Foreground="#C8D6E5" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Key" Foreground="#8888AA" FontSize="11"
                                           MinWidth="70" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbIdleWorkerKey" Width="140"
                                          Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                          FontSize="12"/>
                                <TextBlock Text="Modifier" Foreground="#8888AA" FontSize="11"
                                           MinWidth="60" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbIdleWorkerMod" Width="140"
                                          Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                          FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Shortcut:" Foreground="#404070" FontSize="11" Margin="0,0,6,0"/>
                                <TextBlock x:Name="lblIdleWorkerShortcut" Text="—"
                                           Foreground="#00d4ff" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnSaveIdleWorker" Content="💾  Apply to BIG"
                                        Height="34" Padding="16,0"
                                        Background="#01031A" Foreground="White" BorderBrush="#2980FF"
                                        BorderThickness="2" Cursor="Hand"
                                        IsEnabled="False" Click="BtnSaveIdleWorker_Click"/>
                                <TextBlock x:Name="lblIdleWorkerPath" Text="" Foreground="#404070"
                                           FontSize="10" Margin="12,0,0,0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock x:Name="lblIdleWorkerStatus" Text="" FontSize="11"
                                       Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Beacon Key -->
                    <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Beacon Key" FontSize="13" FontWeight="Bold"
                                       Foreground="#C8D6E5" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Key" Foreground="#8888AA" FontSize="11"
                                           MinWidth="70" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbBeaconKey" Width="140"
                                          Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                          FontSize="12"/>
                                <TextBlock Text="Modifier" Foreground="#8888AA" FontSize="11"
                                           MinWidth="60" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbBeaconMod" Width="140"
                                          Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                          FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Shortcut:" Foreground="#404070" FontSize="11" Margin="0,0,6,0"/>
                                <TextBlock x:Name="lblBeaconShortcut" Text="—"
                                           Foreground="#00d4ff" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnSaveBeacon" Content="💾  Apply to BIG"
                                        Height="34" Padding="16,0"
                                        Background="#01031A" Foreground="White" BorderBrush="#2980FF"
                                        BorderThickness="2" Cursor="Hand"
                                        IsEnabled="False" Click="BtnSaveBeacon_Click"/>
                                <TextBlock x:Name="lblBeaconPath" Text="(Not found in BIG)"
                                           Foreground="#404070" FontSize="10"
                                           Margin="12,0,0,0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock x:Name="lblBeaconStatus" Text="" FontSize="11"
                                       Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Nuke Battlemaster Fix -->
                    <Border Background="#07091C" BorderBrush="#1A2A50" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Nuke General — Battlemaster Image Fix"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#C8D6E5" Margin="0,0,0,6"/>
                            <TextBlock FontSize="11" Foreground="#8888AA" Margin="0,0,0,10"
                                       TextWrapping="Wrap"
                                       Text="Changes SNBattlemaster → SNNukeBtleMstr_L in CommandButton.ini (Nuke General War Factory icon fix)."/>
                            <Button x:Name="btnNukeBattlemasterFix" Content="🔧  Fix"
                                    Height="34" Padding="16,0"
                                    Background="#01031A" Foreground="White" BorderBrush="#2980FF"
                                    BorderThickness="2" Cursor="Hand"
                                    Click="BtnNukeBattlemasterFix_Click"/>
                            <TextBlock x:Name="lblNukeBattlemasterStatus" Text="" FontSize="11"
                                       Foreground="#55CC88" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- COMMAND CARD -->
                <Grid x:Name="PanelCommandCard" Visibility="Collapsed">
                    <Grid.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="5"/>
                            <Setter Property="MinWidth" Value="5"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="#0A0C20">
                                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="1,4">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                                  Opacity="0" Focusable="False" IsTabStop="False"/>
                                                </Track.DecreaseRepeatButton>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                                  Opacity="0" Focusable="False" IsTabStop="False"/>
                                                </Track.IncreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border CornerRadius="2" Background="#404070"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Button">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True"
                                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#132858"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#5BA4FF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#07163A"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#5F6C86"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter TargetName="border" Property="Background" Value="#070D22"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#1E2A44"/>
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="COMMAND CARD" Style="{StaticResource SectionHeaderStyle}"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <!-- Army selector + filter -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Army:" Foreground="#8888AA" FontSize="12" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbCommandCardArmy" Width="200"
                                  Background="#1E1E2E" Foreground="White" BorderBrush="#404060"
                                  VerticalAlignment="Center"
                                  SelectionChanged="CmbCommandCardArmy_SelectionChanged"/>
                        <TextBlock Text="  Show:" Foreground="#8888AA" FontSize="12" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="12,0,8,0"/>
                        <RadioButton x:Name="rbCcAll" Content="All" Foreground="White" FontSize="12"
                                     GroupName="CcFilter" IsChecked="True" Margin="0,0,10,0"
                                     VerticalAlignment="Center" Checked="CcFilter_Checked"/>
                        <RadioButton x:Name="rbCcBuildings" Content="Buildings" Foreground="White" FontSize="12"
                                     GroupName="CcFilter" Margin="0,0,10,0"
                                     VerticalAlignment="Center" Checked="CcFilter_Checked"/>
                        <RadioButton x:Name="rbCcUnits" Content="Units" Foreground="White" FontSize="12"
                                     GroupName="CcFilter" VerticalAlignment="Center"
                                     Checked="CcFilter_Checked"/>
                    </StackPanel>

                    <Button x:Name="btnApplyAllKeysFromLabels" Content="Apply all keys to images (from labels)"
                            Margin="0,8,0,0" HorizontalAlignment="Left" Padding="14,6" FontSize="11"
                            FontWeight="Bold" Cursor="Hand" Background="#1A3060" Foreground="#FFDD33"
                            BorderBrush="#2980FF" BorderThickness="1"
                            Click="BtnApplyAllKeysFromLabels_Click"
                            ToolTip="Reads each slot's current CSF label (&amp; shortcut) and paints that letter on the button image."/>
                    <TextBlock Text="Uses the &amp; shortcut already in each label (vanilla / saved CSF) — all armies, all slots."
                               Foreground="#666688" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <Border x:Name="PanelCommandCardProgress"
                            Visibility="Collapsed"
                            Background="#07091C" BorderBrush="#2A2A55" BorderThickness="1"
                            Padding="8,6" Margin="0,6,0,0">
                        <StackPanel>
                            <TextBlock x:Name="lblCommandCardProgress"
                                       Text="Working..."
                                       Foreground="#FFDD33" FontSize="11" Margin="0,0,0,5"/>
                            <ProgressBar Height="8" IsIndeterminate="True"
                                         Background="#111830" Foreground="#2980FF"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="lblCommandCardStatus"
                               Foreground="#55CC88" FontSize="11" Margin="0,6,0,0"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Tümü: şablon kartlar | Ordu: bina/ünite listesi -->
                    <Grid Grid.Row="2" MaxHeight="520">
                        <!-- Global layout editor (Army = Tümü) -->
                        <ScrollViewer x:Name="PanelCcGlobalLayout" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Template cards — keys you enter apply to the same slot position on every army's command cards."
                                           Foreground="#8888AA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <TextBlock Text="Normal command card (slots 1–14)" Foreground="#C8D6E5"
                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                <ContentControl x:Name="GlobalNormalCardHost" Margin="0,0,0,8"/>
                                <TextBlock Text="Buildings" Foreground="#8888AA" FontSize="11" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="btnApplyNormalLabelsBuildings" Content="Apply labels"
                                            Padding="12,5" FontSize="11" Cursor="Hand"
                                            Background="#0A1A3A" Foreground="White" BorderBrush="#2980FF"
                                            BorderThickness="1" Click="BtnApplyNormalLabelsBuildings_Click"/>
                                    <Button x:Name="btnApplyNormalImagesBuildings" Content="Apply keys to images"
                                            Margin="8,0,0,0" Padding="12,5" FontSize="11" FontWeight="Bold"
                                            Cursor="Hand" Background="#1A3060" Foreground="#FFDD33"
                                            BorderBrush="#2980FF" BorderThickness="1"
                                            Click="BtnApplyNormalImagesBuildings_Click"/>
                                </StackPanel>
                                <TextBlock Text="Units" Foreground="#8888AA" FontSize="11" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Button x:Name="btnApplyNormalLabelsUnits" Content="Apply labels"
                                            Padding="12,5" FontSize="11" Cursor="Hand"
                                            Background="#0A1A3A" Foreground="White" BorderBrush="#2980FF"
                                            BorderThickness="1" Click="BtnApplyNormalLabelsUnits_Click"/>
                                    <Button x:Name="btnApplyNormalImagesUnits" Content="Apply keys to images"
                                            Margin="8,0,0,0" Padding="12,5" FontSize="11" FontWeight="Bold"
                                            Cursor="Hand" Background="#1A3060" Foreground="#FFDD33"
                                            BorderBrush="#2980FF" BorderThickness="1"
                                            Click="BtnApplyNormalImagesUnits_Click"/>
                                </StackPanel>
                                <TextBlock Text="General's powers (slots 1–24)" Foreground="#C8D6E5"
                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                <ContentControl x:Name="GlobalStarCardHost" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button x:Name="btnApplyStarLabels" Content="Apply labels"
                                            Padding="12,5" FontSize="11" Cursor="Hand"
                                            Background="#0A1A3A" Foreground="White" BorderBrush="#2980FF"
                                            BorderThickness="1" Click="BtnApplyStarLabels_Click"/>
                                    <Button x:Name="btnApplyStarImages" Content="Apply keys to images"
                                            Margin="8,0,0,0" Padding="12,5" FontSize="11" FontWeight="Bold"
                                            Cursor="Hand" Background="#1A3060" Foreground="#FFDD33"
                                            BorderBrush="#2980FF" BorderThickness="1"
                                            Click="BtnApplyStarImages_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Per-unit editor (specific army) -->
                        <Grid x:Name="PanelCcUnitEditor">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" MinWidth="180"/>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="lbCommandCardUnits" Grid.Column="0"
                                 Background="#07091C" Foreground="White" BorderBrush="#2A2A55"
                                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Margin="0,0,10,0"
                                 PreviewMouseWheel="LbCommandCardUnits_PreviewMouseWheel"
                                 SelectionChanged="LbCommandCardUnits_SelectionChanged">
                        </ListBox>

                        <!-- Right: selected unit label + grid + slot info -->
                        <ScrollViewer Grid.Column="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="0,0,6,0">
                            <StackPanel>
                            <TextBlock x:Name="lblSelectedUnit"
                                       Text="(select a unit or building)"
                                       Foreground="#88CCFF" FontSize="13" FontWeight="Bold"
                                       FontFamily="Segoe UI" Margin="0,0,0,8"/>

                            <ContentControl x:Name="CommandCardGridHost" Margin="0,0,0,12"/>

                            <!-- Slot detail panel (shown when a slot button is clicked) -->
                            <Border x:Name="SlotInfoPanel" Visibility="Collapsed"
                                    Background="#07091C" BorderBrush="#2A2A55" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,0,0">
                                <StackPanel>
                                    <!-- Icon + ID row -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Image x:Name="imgSlotPreview" Width="48" Height="48"
                                               Stretch="Uniform" Margin="0,0,10,0"
                                               VerticalAlignment="Top"/>
                                        <StackPanel>
                                            <TextBlock x:Name="lblSlotId"
                                                       Foreground="#606080" FontSize="10"
                                                       FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="lblSlotFormatted"
                                                       FontSize="13" FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Raw-text editor + shortcut key -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBox x:Name="lblSlotText"
                                                 Background="#1E1E2E" Foreground="White"
                                                 BorderBrush="#404060" BorderThickness="1"
                                                 Padding="6,4" FontSize="12" Width="220" Margin="0,0,8,0"
                                                 CaretBrush="White" SelectionBrush="#2980FF"
                                                 GotFocus="LblSlotText_GotFocus"
                                                 LostFocus="LblSlotText_LostFocus"
                                                 TextChanged="LblSlotText_TextChanged"/>
                                        <TextBlock Text="Key:" Foreground="#8888AA" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox x:Name="txtSlotHotkey"
                                                 Background="#1E1E2E" Foreground="#FFDD33"
                                                 BorderBrush="#404060" BorderThickness="1"
                                                 Padding="4,4" FontSize="12" Width="28"
                                                 MaxLength="1" CharacterCasing="Upper"
                                                 VerticalContentAlignment="Center"
                                                 CaretBrush="White"
                                                 ToolTip="Shortcut letter (e.g. F)"
                                                 TextChanged="TxtSlotHotkey_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="btnSlotUndo" Content="Undo"
                                                Click="BtnSlotUndo_Click" IsEnabled="False"
                                                Background="#1E1E2E" Foreground="#C8D6E5"
                                                BorderBrush="#404060" BorderThickness="1"
                                                Padding="10,4" FontSize="11" Cursor="Hand"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="btnSlotApplyLabel" Content="Apply label"
                                                Click="BtnSlotApplyLabel_Click" IsEnabled="False"
                                                Background="#0A1A3A" Foreground="White"
                                                BorderBrush="#2980FF" BorderThickness="1"
                                                Padding="10,4" FontSize="11" Cursor="Hand"/>
                                        <Button x:Name="btnSlotApplyImages" Content="Apply keys to images"
                                                Margin="8,0,0,0" Click="BtnSlotApplyImages_Click"
                                                IsEnabled="False"
                                                Background="#1A3060" Foreground="#FFDD33"
                                                BorderBrush="#2980FF" BorderThickness="1"
                                                Padding="10,4" FontSize="11" FontWeight="Bold" Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
